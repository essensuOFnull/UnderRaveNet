{
  "manifest_version": 3,
  "name": "WebRTC Tunnel Helper",
  "version": "1.0",
  "description": "Помогает другу получить доступ к интернету через ваше соединение",
  "permissions": [
    "storage",
    "sockets",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  }
}