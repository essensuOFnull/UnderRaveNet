{
  "manifest_version": 3,
  "name": "WebRTC Tunnel Helper",
  "version": "1.1",
  "description": "Помогает друзьям получить доступ к интернету через WebRTC DataChannel",
  "permissions": [
    "storage",
    "sockets"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}